<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">HelpDeskHero</a>
    </div>
</div>

<div class="nav-scrollable">
    <nav class="flex-column">
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="dashboard">Dashboard</NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="tickets">Zgłoszenia</NavLink>
                </div>

                <AuthorizeView Policy="CanManageTickets" Context="navCreate">
                    <Authorized>
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="tickets/create">Nowe zgłoszenie</NavLink>
                        </div>
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="tickets/deleted">Kosz</NavLink>
                        </div>
                    </Authorized>
                </AuthorizeView>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="account/security">Bezpieczeństwo konta</NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="notifications">
                        Powiadomienia
                        @if (_unreadCount > 0)
                        {
                            <span class="badge bg-danger ms-2">@_unreadCount</span>
                        }
                    </NavLink>
                </div>

                <AuthorizeView Roles="Admin" Context="navAdmin">
                    <Authorized>
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="admin">Panel admina</NavLink>
                        </div>
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="admin/audit">Audit log</NavLink>
                        </div>
                    </Authorized>
                </AuthorizeView>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="logout">Wyloguj</NavLink>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="login">Logowanie</NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    [Inject] private HelpDeskHero.UI.Services.Api.NotificationApiClient NotificationApi { get; set; } = default!;

    private int _unreadCount;

    protected override async Task OnInitializedAsync()
    {
        var items = await NotificationApi.GetMineAsync();
        _unreadCount = items.Count(x => !x.IsRead);
    }
}
