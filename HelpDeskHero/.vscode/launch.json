    {
      "name": ".NET Launch UI",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-all",
      "program": "${workspaceFolder}/src/HelpDeskHero.UI/bin/Debug/net10.0/HelpDeskHero.UI.dll",
      "cwd": "${workspaceFolder}/src/HelpDeskHero.UI",
      "stopAtEntry": false
    }
  ]
}